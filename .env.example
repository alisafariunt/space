# Environment Configuration for JWT Authentication System
# ======================================================
# This file documents all required environment variables for deployment.
# DO NOT commit actual values - set them in your Vercel Dashboard instead.

# JWT Security
# ------------
# Secret key used to sign JWT tokens
# Generate a secure random value using: openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32

# JWT token expiration times
# Access token expiration (how long before user needs to refresh)
JWT_ACCESS_EXPIRY=30m

# Refresh token expiration (how long before user needs to re-login)
JWT_REFRESH_EXPIRY=30d

# Application Environment
# -----------------------
# Environment mode: development, staging, or production
NODE_ENV=production

# CORS Configuration
# ------------------
# Comma-separated list of allowed origins for CORS
# Include both www and non-www versions if applicable
ALLOWED_ORIGINS=https://alisafari.space,https://www.alisafari.space

# Rate Limiting
# -------------
# Maximum number of requests allowed per time window
RATE_LIMIT_MAX=60

# Time window for rate limiting in milliseconds (60000ms = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Debugging
# ---------
# Enable debug mode for additional logging (true/false)
DEBUG=false

# Database Configuration
# ----------------------
# Turso database URL
# Get from: https://turso.tech/
TURSO_DATABASE_URL=your-turso-url

# Turso authentication token
# Get from: https://turso.tech/
TURSO_AUTH_TOKEN=your-turso-token

# Deployment Notes
# ----------------
# 1. Never commit this file with actual values
# 2. Set all variables in Vercel Dashboard (Settings > Environment Variables)
# 3. JWT_SECRET should be unique and randomly generated
# 4. Use different JWT_SECRET values for development and production
# 5. ALLOWED_ORIGINS should match your actual domain(s)
# 6. Rate limits can be adjusted based on your needs
