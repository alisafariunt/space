# Environment Configuration
# ======================================================
# Documentation of every variable the deployed app expects.
# DO NOT commit actual values — set them in the Vercel Dashboard.

# JWT Security
# ------------
# Required. Server refuses to start if missing or shorter than 32 chars.
# Generate a secure random value: openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32

# Optional overrides
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12

# Application Environment
# -----------------------
NODE_ENV=production

# CORS Configuration
# ------------------
# Comma-separated list of allowed origins. Origins not on this list cannot
# call the API with credentials. The server trims whitespace.
ALLOWED_ORIGINS=https://alisafari.space,https://www.alisafari.space,https://flow.alisafari.space

# Cookie domain for auth cookies. Leading dot scopes to all subdomains.
# Override only if you're hosting on a different domain.
COOKIE_DOMAIN=.alisafari.space

# Rate Limiting (TTS endpoint, best-effort per-process)
# -----------------------------------------------------
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Database — Turso (LibSQL)
# -------------------------
# Get from: https://turso.tech/
TURSO_DATABASE_URL=your-turso-url
TURSO_AUTH_TOKEN=your-turso-token

# Supabase — only used by the daily keep-alive cron (api/ping-supabase.js)
# ------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Cron secret. Vercel attaches "Authorization: Bearer $CRON_SECRET" to
# scheduled requests when this is set; the cron endpoint refuses any
# request without it. Generate with: openssl rand -hex 32
CRON_SECRET=generate-with-openssl-rand-hex-32

# OpenRouter (api/summary.js)
# ---------------------------
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=xiaomi/mimo-v2-flash:free
OPENROUTER_SITE_URL=https://alisafari.space
OPENROUTER_APP_NAME=study-guide

# Murf TTS (api/tts.js)
# ---------------------
MURF_API_KEY=your-murf-key

# Deployment Notes
# ----------------
# 1. Never commit this file with actual values.
# 2. Set all variables in Vercel Dashboard (Settings > Environment Variables).
# 3. JWT_SECRET, CRON_SECRET, TURSO_AUTH_TOKEN, SUPABASE_ANON_KEY,
#    OPENROUTER_API_KEY, and MURF_API_KEY must each be rotated separately
#    if previously committed or shared.
